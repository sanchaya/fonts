<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Suggest a Font - ಫಾಂಟ್ಸ್ ಸಂಚಯ</title>
    <base href="/">
    <link rel="icon" type="image/png" href="/img/app-icon-light.png">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/main.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    <script src="/js/home.js"></script>
    <style>
        .suggestion-form {
            max-width: 600px;
            margin: 40px auto;
            padding: 30px;
            background: var(--third-color);
            border-radius: 16px;
            box-shadow: var(--card-shadow);
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            font-weight: 600;
            color: var(--text-color1);
            margin-bottom: 8px;
        }
        .form-group input[type="text"],
        .form-group input[type="email"],
        .form-group textarea {
            width: 100%;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid var(--border-color);
            background: var(--third-color);
            color: var(--text-color1);
            font-size: 14px;
            transition: border-color 0.3s ease;
        }
        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--text-color3);
        }
        .form-group input[type="file"] {
            padding: 10px;
            border-radius: 8px;
            border: 1px dashed var(--border-color);
            background: var(--text-background);
        }
        button[type="submit"] {
            background: linear-gradient(135deg, #4361ee 0%, #3f37c9 100%);
            color: white;
            padding: 14px 30px;
            border: none;
            cursor: pointer;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            width: 100%;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        button[type="submit"]:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(67, 97, 238, 0.3);
        }
        .form-section {
            background: var(--text-background);
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 20px;
        }
        .form-section h4 {
            color: var(--text-color3);
            margin-bottom: 15px;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 10px;
        }
    </style>
    <script>
        function isValidEmail(email) {
            var emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            return emailRegex.test(email);
        }
        function isValidFileExtension(fileName, validExtensions) {
            var fileExtension = fileName.split('.').pop().toLowerCase();
            return validExtensions.includes(fileExtension);
        }
        function validateForm() {
            var email = document.getElementById('email').value;
            var fileName = document.getElementById('fontfile').value;
            var validExtensions = ['ttf', 'otf', 'woff', 'woff2'];
            if (!isValidEmail(email)) {
                alert('Invalid email address. Please enter a valid email.');
                return false;
            }
            if (fileName && !isValidFileExtension(fileName, validExtensions)) {
                alert('Invalid file format. Please upload a file with valid extensions: ' + validExtensions.join(', '));
                return false;
            }
            var formData = new FormData($('form')[0]);
            $.ajax({
                url: '/submit-suggestion',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(response) {
                    alert(response.message || 'Font suggestion submitted successfully!');
                    window.location.href = '/';
                },
                error: function(error) {
                    console.error('Error:', error);
                    alert('Failed to submit font suggestion.');
                }
            });
            return false;
        }
    </script>
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="suggestion-form">
        <h2>Suggest a Font</h2>
        <form onsubmit="return validateForm();" action="/submit-suggestion" method="POST" enctype="multipart/form-data">
            <div class="form-section">
                <h4>Font Information</h4>
                <div class="form-group">
                    <label for="font-name">Font Name</label>
                    <input type="text" id="font-name" name="font-name" required>
                </div>
                <div class="form-group">
                    <label for="fontStyle">Font Style</label>
                    <input type="text" id="fontStyle" name="fontStyle" placeholder="e.g., Regular, Bold, Italic" required>
                </div>
                <div class="form-group">
                    <label for="designedBy">Designed By</label>
                    <input type="text" id="designedBy" name="designedBy" required>
                </div>
                <div class="form-group">
                    <label for="fontLicense">Font License</label>
                    <input type="text" id="fontLicense" name="fontLicense" placeholder="e.g., SIL OFL, Proprietary" required>
                </div>
                <div class="form-group">
                    <label for="fontURL">Source URL</label>
                    <input type="text" id="fontURL" name="fontURL" placeholder="Link to font source or download" required>
                </div>
            </div>

            <div class="form-section">
                <h4>Sample Text</h4>
                <div class="form-group">
                    <label for="sampleParagraph">Sample Paragraph (in Kannada)</label>
                    <textarea id="sampleParagraph" name="sampleParagraph" rows="3" placeholder="Enter sample text in Kannada" required></textarea>
                </div>
            </div>

            <div class="form-section">
                <h4>Submitter Information</h4>
                <div class="form-group">
                    <label for="submitterName">Your Name</label>
                    <input type="text" id="submitterName" name="submitterName" required>
                </div>
                <div class="form-group">
                    <label for="email">Email ID</label>
                    <input type="email" id="email" name="email" required>
                </div>
            </div>

            <div class="form-section">
                <h4>Font File</h4>
                <div class="form-group">
                    <label for="fontfile">Upload Font File (TTF, OTF, WOFF, WOFF2)</label>
                    <input type="file" id="fontfile" name="fontfile" accept=".ttf,.otf,.woff,.woff2">
                </div>
            </div>

            <button type="submit" id="submitBtn">Submit Font Suggestion</button>
        </form>
    </div>

    <footer class="site-footer">
        <div class="footer-content">
            <div class="footer-links">
                <a href="/">ಫಾಂಟ್ಗಳನ್ನು ಜಾಲಾಡಿ</a>
                <a href="/about">ಯೋಜನೆಯ ಬಗ್ಗೆ</a>
                <a href="/bug-reports">Bug Reports</a>
                <a href="/getSuggestionForm">ಫಾಂಟನ್ನು ಸೂಚಿಸಿ</a>
            </div>
            <div class="footer-copyright">
                &copy; <%= new Date().getFullYear() %> ಸಂಚಯ ಮತ್ತು ಸಂಚಿ ಫೌಂಡೇಶನ್
            </div>
        </div>
    </footer>
</body>
</html>