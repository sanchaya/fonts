<div class="paragraph-wrapper">
    <div class="input-row">
        <div class="field-wrapper">
            <input type="text" maxlength="100" autocomplete="off" class="kan-ime" id="type-text">
            <div class="field-placeholder"><span>Type Text</span></div>
        </div>
        <div id="slider-align">
            <div class="slidecontainer">
                <input type="range" min="8" max="100" value="50" name="range" class="slider" id="myRange">
                <output onforminput="value = range.valueAsNumber;"></output>
            </div>
        </div>
    </div>
    <div class="para-output" id="in-para-txt">
        <p></p>
    </div>
</div>