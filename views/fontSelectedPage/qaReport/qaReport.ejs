<% if (typeof fontQuality !== 'undefined' && fontQuality && fontQuality.totalScore !== undefined) { %>
<div class="qa-report">
  <div class="qa-strip">
    <div class="qa-strip-errors">
      <span class="qa-strip-icon">&#9940;</span>
      <span class="qa-strip-count"><%= fontQuality.errors %></span>
      <span class="qa-strip-label">Errors</span>
    </div>
    <div class="qa-strip-warnings">
      <span class="qa-strip-icon">&#9888;&#65039;</span>
      <span class="qa-strip-count"><%= fontQuality.warnings %></span>
      <span class="qa-strip-label">Warnings</span>
    </div>
    <div class="qa-strip-score">
      <span class="qa-strip-grade" style="color:<%= fontQuality.gradeColor %>"><%= fontQuality.grade %></span>
      <span class="qa-strip-pct"><%= fontQuality.totalScore %>%</span>
      <span class="qa-strip-label"><%= fontQuality.gradeLabel %></span>
    </div>
  </div>

  <div class="qa-report-iframe-container">
    <iframe class="qa-report-iframe" src="/qa-report/<%= encodeURIComponent(fontFamily) %>" frameborder="0" loading="lazy"></iframe>
  </div>
</div>
<% } else { %>
<div class="qa-report">
  <div class="qa-empty">
    <div class="qa-empty-icon"><%- '\uD83D\uDCC4' %></div>
    <h3>Quality Report Not Available</h3>
    <p>Unable to generate a quality assessment for this font.</p>
  </div>
</div>
<% } %>

<style>
.qa-report {
  padding: 20px;
  color: var(--text-color1);
}

/* Error/Warning/Score Strip */
.qa-strip {
  display: flex;
  gap: 12px;
  margin-bottom: 24px;
  align-items: stretch;
}

.qa-strip > div {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16px 12px;
  border-radius: 12px;
  text-align: center;
}

.qa-strip-errors {
  background: #ffebee;
  color: #c62828;
}

.qa-strip-warnings {
  background: #fff3e0;
  color: #e65100;
}

.qa-strip-score {
  background: var(--third-color);
  box-shadow: var(--card-shadow);
}

.qa-strip-icon {
  font-size: 20px;
}

.qa-strip-count {
  font-size: 28px;
  font-weight: 800;
  line-height: 1.2;
}

.qa-strip-grade {
  font-size: 28px;
  font-weight: 800;
  line-height: 1.2;
}

.qa-strip-pct {
  font-size: 14px;
  font-weight: 700;
  color: var(--text-color1);
}

.qa-strip-label {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  opacity: 0.8;
}

body.dark .qa-strip-errors { background: rgba(198,40,40,0.2); }
body.dark .qa-strip-warnings { background: rgba(230,81,0,0.2); }

/* Iframe */
.qa-report-iframe-container {
  width: 100%;
  border: 1px solid var(--border-color);
  border-radius: 12px;
  overflow: hidden;
  background: #fff;
}

.qa-report-iframe {
  width: 100%;
  height: 800px;
  display: block;
}

body.dark .qa-report-iframe-container {
  background: #0f172a;
  border-color: #1e293b;
}

.qa-empty {
  text-align: center;
  padding: 60px 20px;
}

.qa-empty h3 { margin: 0 0 8px 0; }
.qa-empty p { margin: 0; font-size: 14px; color: var(--span-color); }
.qa-empty-icon { font-size: 48px; margin-bottom: 12px; }
</style>

<script>
(function() {
  const iframe = document.querySelector('.qa-report-iframe');
  if (!iframe) return;
  iframe.addEventListener('load', function() {
    try {
      const doc = iframe.contentDocument || iframe.contentWindow.document;
      const body = doc.body;
      const height = body.scrollHeight;
      if (height > 100) {
        iframe.style.height = height + 'px';
      }
    } catch(e) {}
  });
  // Retry height adjustment after fonts/images load
  setTimeout(function() {
    try {
      const doc = iframe.contentDocument || iframe.contentWindow.document;
      const body = doc.body;
      const height = body.scrollHeight;
      if (height > 100) {
        iframe.style.height = height + 'px';
      }
    } catch(e) {}
  }, 1000);
})();
</script>