<% if (typeof qaReportHtml !== 'undefined' && qaReportHtml) { %>
<div class="qa-report">
  <!-- QA Header -->
  <header class="qa-header">
    <div>
      <div class="title">ಕನ್ನಡ Font Quality Inspector</div>
      <div class="sub">Sanchaya Font Tools · typetest.sanchaya.net</div>
    </div>
  </header>

  <!-- Sub-tab navigation for sections -->
  <div class="qa-subtabs">
    <button class="qa-subtab active" data-section="all">Overview</button>
    <button class="qa-subtab" data-section="Issues">Issues</button>
    <button class="qa-subtab" data-section="Coverage">Coverage</button>
    <button class="qa-subtab" data-section="Features">Features</button>
    <button class="qa-subtab" data-section="Script">Scripts</button>
    <button class="qa-subtab" data-section="GSUB">GSUB</button>
    <button class="qa-subtab" data-section="GPOS">GPOS</button>
    <button class="qa-subtab" data-section="Metadata">Metadata</button>
    <button class="qa-subtab" data-section="Glyph">Glyphs</button>
  </div>

  <div class="qa-report-body">
    <%- qaReportHtml %>
  </div>
</div>

<style>
.qa-subtabs {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
  padding: 8px 0;
  margin-bottom: 0;
  position: sticky;
  top: 0;
  z-index: 20;
  background: var(--bg-color);
}

.qa-subtab {
  padding: 6px 14px;
  border: 1px solid var(--border-color);
  border-radius: 20px;
  background: transparent;
  color: var(--text-color1);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s ease;
  white-space: nowrap;
}

.qa-subtab:hover {
  background: var(--primary-color);
  border-color: var(--primary-color);
  color: #fff;
}

.qa-subtab.active {
  background: var(--primary-color);
  border-color: var(--primary-color);
  color: #fff;
}

.qa-report-body .qa-section {
  display: none;
}

.qa-report-body.show-all .qa-section {
  display: block;
}

.qa-report-body.show-section-Issues .qa-section:not([data-qa-section="Issues"]),
.qa-report-body.show-section-Coverage .qa-section:not([data-qa-section="Coverage"]),
.qa-report-body.show-section-Features .qa-section:not([data-qa-section="Features"]),
.qa-report-body.show-section-Script .qa-section:not([data-qa-section="Script"]),
.qa-report-body.show-section-GSUB .qa-section:not([data-qa-section="GSUB"]),
.qa-report-body.show-section-GPOS .qa-section:not([data-qa-section="GPOS"]),
.qa-report-body.show-section-Metadata .qa-section:not([data-qa-section="Metadata"]),
.qa-report-body.show-section-Glyph .qa-section:not([data-qa-section="Glyph"]) {
  display: none;
}

.qa-report-body.show-section-Issues .qa-section[data-qa-section="Issues"],
.qa-report-body.show-section-Coverage .qa-section[data-qa-section="Coverage"],
.qa-report-body.show-section-Features .qa-section[data-qa-section="Features"],
.qa-report-body.show-section-Script .qa-section[data-qa-section="Script"],
.qa-report-body.show-section-GSUB .qa-section[data-qa-section="GSUB"],
.qa-report-body.show-section-GPOS .qa-section[data-qa-section="GPOS"],
.qa-report-body.show-section-Metadata .qa-section[data-qa-section="Metadata"],
.qa-report-body.show-section-Glyph .qa-section[data-qa-section="Glyph"] {
  display: block;
}
</style>

<script>
(function() {
  const body = document.querySelector('.qa-report-body');
  if (!body) return;

  // Label each .qa-section with its title text as a data attribute
  body.querySelectorAll('.qa-section').forEach(function(section) {
    const titleEl = section.querySelector('.qa-section-title');
    if (titleEl) {
      var text = titleEl.textContent.trim();
      if (text.indexOf('Issues') !== -1) section.dataset.qaSection = 'Issues';
      else if (text.indexOf('Kannada Unicode Coverage') !== -1) section.dataset.qaSection = 'Coverage';
      else if (text.indexOf('OpenType Feature Coverage') !== -1) section.dataset.qaSection = 'Features';
      else if (text.indexOf('Script & Language') !== -1) section.dataset.qaSection = 'Script';
      else if (text.indexOf('GSUB') !== -1) section.dataset.qaSection = 'GSUB';
      else if (text.indexOf('GPOS') !== -1) section.dataset.qaSection = 'GPOS';
      else if (text.indexOf('Font Metadata') !== -1) section.dataset.qaSection = 'Metadata';
      else if (text.indexOf('Glyph Inventory') !== -1) section.dataset.qaSection = 'Glyph';
    }
  });

  // Tab click handler
  document.querySelectorAll('.qa-subtab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.qa-subtab').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var section = btn.dataset.section;
      body.className = 'qa-report-body' + (section === 'all' ? ' show-all' : ' show-section-' + section);
    });
  });
})();
</script>
<% } else if (typeof fontQuality !== 'undefined' && fontQuality && fontQuality.totalScore !== undefined) { %>
<div class="qa-report">
  <div class="qa-fallback">
    <div class="qa-fallback-score">
      <span class="qa-fallback-grade" style="color:<%= fontQuality.gradeColor %>"><%= fontQuality.grade %></span>
      <span class="qa-fallback-pct"><%= fontQuality.totalScore %>%</span>
      <span class="qa-fallback-label"><%= fontQuality.gradeLabel %></span>
    </div>
    <div class="qa-fallback-issues">
      <span class="qa-fallback-badge">&#9940; <%= fontQuality.errors %> Errors</span>
      <span class="qa-fallback-badge">&#9888;&#65039; <%= fontQuality.warnings %> Warnings</span>
    </div>
    <div class="qa-fallback-note">Detailed QA report unavailable. Run font inspector to generate full analysis.</div>
  </div>
</div>
<% } else { %>
<div class="qa-report">
  <div class="qa-empty">
    <div class="qa-empty-icon"><%- '\uD83D\uDCC4' %></div>
    <h3>Quality Report Not Available</h3>
    <p>Unable to generate a quality assessment for this font.</p>
  </div>
</div>
<% } %>

<style>
.qa-report {
  color: var(--text-color1);
}

.qa-fallback {
  padding: 24px;
  background: var(--surface);
  border: 1px solid var(--border-color);
  border-radius: 12px;
  text-align: center;
}

.qa-fallback-score {
  margin-bottom: 16px;
}

.qa-fallback-grade {
  font-size: 32px;
  font-weight: 800;
}

.qa-fallback-pct {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-color1);
  margin-left: 8px;
}

.qa-fallback-label {
  display: block;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  opacity: 0.8;
  margin-top: 4px;
}

.qa-fallback-issues {
  display: flex;
  gap: 12px;
  justify-content: center;
  margin-bottom: 12px;
}

.qa-fallback-badge {
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 600;
}

.qa-fallback-badge:first-child {
  background: #ffebee;
  color: #c62828;
}

.qa-fallback-badge:last-child {
  background: #fff3e0;
  color: #e65100;
}

.qa-fallback-note {
  font-size: 12px;
  color: var(--span-color);
}

.qa-empty {
  text-align: center;
  padding: 60px 20px;
}

.qa-empty h3 { margin: 0 0 8px 0; }
.qa-empty p { margin: 0; font-size: 14px; color: var(--span-color); }
.qa-empty-icon { font-size: 48px; margin-bottom: 12px; }
</style>
