<div class="overview-section">
<% for(const key in overview){ %>
    <h3 class="overview-title"><%= key.charAt(0).toUpperCase() + key.slice(1) %></h3>
    <div class="overview-char-cnt">
    <% for(let i=0; i<overview[key].length; i++){ %>
        <div class="overview-char">
            <span><%= overview[key][i] %></span>
        </div>
    <% } %>  
    </div>
<% } %>
</div>
