<div class="bugreport-container">
    <h3>Report a Bug</h3>
    <p class="bugreport-intro">Found an issue with this font? Let us know and we'll help get it fixed.</p>
    
    <form id="bugReportForm" class="bugreport-form">
        <input type="hidden" name="fontFamily" value="<%= fontFamily %>">
        <input type="hidden" name="fontName" value="<%= font %>">
        
        <div class="form-group">
            <label for="email">Email (optional)</label>
            <input type="email" id="email" name="email" placeholder="your@email.com">
            <span class="help-text">We may contact you for more details</span>
        </div>
        
        <div class="form-group">
            <label for="description">Bug Description *</label>
            <textarea id="description" name="description" rows="5" placeholder="Describe the issue you're experiencing..." required></textarea>
        </div>
        
        <div class="form-row">
            <div class="form-group half">
                <label for="browser">Browser</label>
                <select id="browser" name="browser">
                    <option value="">Select browser</option>
                    <option value="Chrome">Chrome</option>
                    <option value="Firefox">Firefox</option>
                    <option value="Safari">Safari</option>
                    <option value="Edge">Edge</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="form-group half">
                <label for="os">Operating System</label>
                <select id="os" name="os">
                    <option value="">Select OS</option>
                    <option value="Windows">Windows</option>
                    <option value="macOS">macOS</option>
                    <option value="Linux">Linux</option>
                    <option value="Android">Android</option>
                    <option value="iOS">iOS</option>
                    <option value="Other">Other</option>
                </select>
            </div>
        </div>
        
        <button type="submit" class="btn-submit">Submit Bug Report</button>
    </form>
    
    <div id="bugReportMessage" class="message" style="display: none;"></div>
</div>

<style>
.bugreport-container {
    padding: 20px;
    max-width: 600px;
    margin: 0 auto;
}
.bugreport-container h3 {
    margin-bottom: 10px;
    color: #333;
}
.bugreport-intro {
    color: #666;
    margin-bottom: 20px;
}
.bugreport-form {
    background: #f9f9f9;
    padding: 20px;
    border-radius: 8px;
}
.form-group {
    margin-bottom: 15px;
}
.form-group label {
    display: block;
    font-weight: 600;
    margin-bottom: 5px;
    color: #333;
}
.form-group input,
.form-group textarea,
.form-group select {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 14px;
    box-sizing: border-box;
}
.form-group textarea {
    resize: vertical;
    font-family: inherit;
}
.form-group input:focus,
.form-group textarea:focus,
.form-group select:focus {
    outline: none;
    border-color: #4361ee;
}
.help-text {
    display: block;
    font-size: 12px;
    color: #888;
    margin-top: 4px;
}
.form-row {
    display: flex;
    gap: 15px;
}
.form-group.half {
    flex: 1;
}
.btn-submit {
    background: #dc3545;
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
}
.btn-submit:hover {
    background: #c82333;
}
.message {
    margin-top: 15px;
    padding: 12px;
    border-radius: 4px;
}
.message.success {
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
}
.message.error {
    background: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('bugReportForm');
    var messageDiv = document.getElementById('bugReportMessage');
    
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        var formData = new FormData(form);
        var data = {
            fontFamily: formData.get('fontFamily'),
            fontName: formData.get('fontName'),
            email: formData.get('email'),
            description: formData.get('description'),
            browser: formData.get('browser'),
            os: formData.get('os')
        };
        
        fetch('/submit-bug-report', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
        })
        .then(function(response) {
            return response.json();
        })
        .then(function(result) {
            if (result.success) {
                messageDiv.textContent = 'Thank you! Your bug report has been submitted successfully.';
                messageDiv.className = 'message success';
                messageDiv.style.display = 'block';
                form.reset();
            } else {
                messageDiv.textContent = result.error || 'Failed to submit bug report. Please try again.';
                messageDiv.className = 'message error';
                messageDiv.style.display = 'block';
            }
        })
        .catch(function(err) {
            messageDiv.textContent = 'An error occurred. Please try again.';
            messageDiv.className = 'message error';
            messageDiv.style.display = 'block';
        });
    });
});
</script>
