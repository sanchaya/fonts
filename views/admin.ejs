<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Font Metadata Admin - ಫಾಂಟ್ಸ್ ಸಂಚಯ</title>
    <base href="/">
    <link rel="icon" type="image/png" href="/img/app-icon-light.png">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/all.min.css">
    <link rel="stylesheet" href="/css/home.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    <style>
        body { background: var(--third-color); }
        .admin-container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 30px;
            background: var(--third-color);
            border-radius: 16px;
            box-shadow: var(--card-shadow);
        }
        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border-color);
        }
        .admin-header h1 {
            color: var(--text-color1);
            margin: 0;
        }
        .btn-primary {
            background: #4361ee;
            border: none;
        }
        .btn-primary:hover {
            background: #3f37c9;
        }
        .btn-success {
            background: #28a745;
            border: none;
        }
        table {
            background: var(--third-color);
        }
        table thead {
            background: var(--text-background);
        }
        .status-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }
        .status-complete {
            background: rgba(40, 167, 69, 0.15);
            color: #28a745;
        }
        .status-incomplete {
            background: rgba(255, 193, 7, 0.15);
            color: #ffc107;
        }
        .status-open {
            background: rgba(220, 53, 69, 0.15);
            color: #dc3545;
        }
        .status-resolved {
            background: rgba(40, 167, 69, 0.15);
            color: #28a745;
        }
        .action-btns {
            display: flex;
            gap: 8px;
        }
        .bug-reports-section {
            margin-top: 40px;
            padding-top: 30px;
            border-top: 2px solid var(--border-color);
        }
        .bug-reports-section h2 {
            color: var(--text-color1);
            margin-bottom: 20px;
        }
        .report-card {
            background: var(--third-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 15px;
        }
        .report-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 10px;
        }
        .report-font {
            font-weight: 600;
            color: #4361ee;
        }
        .report-meta {
            font-size: 12px;
            color: #888;
        }
        .report-description {
            color: var(--text-color1);
            margin: 10px 0;
        }
        .report-actions {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <div class="slide-menu-baner">
        <div class="slide-menu">
            <div class="header">
              <a href="/"><img src="img/app-icon-light.png" class="app-icon" alt="app-icon"></a>
              <i class="fa fa-times fa-2x" aria-hidden="true"></i>
            </div>
            <ul class="slide-menu-item">
                <li><a href="/">ಫಾಂಟುಗಳನ್ನು ಜಾಲಾಡಿ</a></li>
                <li><a href="/about">ಯೋಜನೆಯ ಬಗ್ಗೆ</a></li>
            </ul>
        </div>
        <div class="gap-filler"></div>
    </div>
    <nav>
        <div class="left-nav">
            <span class="glyphicon glyphicon-menu-hamburger"></span>
            <a href="/"><img src="img/app-icon-light.png" alt="app-icon" class="app-icon"></a>
        </div>
        <div class="tot-right-nav">
            <div class="right-nav">
                <div class="browse-font-tab">
                    <span><a href="/">ಫಾಂಟುಗಳನ್ನು ಜಾಲಾಡಿ</a></span>
                </div>
                <div class="about-us-tab">
                    <span><a href="/about">ಯೋಜನೆಯ ಬಗ್ಗೆ</a></span>
                </div>
            </div>
            <div class="static-right-nav">
                <div class="dark-light">
                    <input type="checkbox" id="dark-light-toggle" name="dark-light-toggle">
                    <label for="dark-light-toggle" class="dark-light-toggle-icon">
                        <i class="fas fa-sun fa-lg"></i>
                        <i class="fas fa-moon fa-lg"></i>
                    </label>
                </div>
                <div class="selected-family">
                    <span><a href="/getSuggestionForm"><i class="fa fa-plus fa-lg"></i></a></span>
                </div>
            </div>
        </div>
    </nav>

    <div class="admin-container">
        <div class="admin-header">
            <div>
                <h1>Font Metadata Admin</h1>
                <p style="color: var(--span-color);">Manage author, license, and source information for fonts</p>
            </div>
            <div class="action-btns">
                <a href="/export" class="btn btn-success">
                    <i class="glyphicon glyphicon-export"></i> Export
                </a>
                <a href="/" class="btn btn-default">Back to Home</a>
                <a href="/logout" class="btn btn-danger">Logout</a>
            </div>
        </div>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Font Family</th>
                    <th>Author</th>
                    <th>License</th>
                    <th>Foundry</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% Object.keys(fonts).forEach(family => { %>
                    <% const meta = metadata[family] || {} %>
                    <% const isComplete = meta.author && meta.license && meta.license !== 'Unknown' && meta.author !== 'Not Available' %>
                    <tr>
                        <td><strong><%= fonts[family].family %></strong></td>
                        <td><%= meta.author || 'Not Available' %></td>
                        <td><%= meta.license || 'Unknown' %></td>
                        <td><%= meta.foundry || '-' %></td>
                        <td>
                            <span class="status-badge <%= isComplete ? 'status-complete' : 'status-incomplete' %>">
                                <%= isComplete ? 'Complete' : 'Incomplete' %>
                            </span>
                        </td>
                        <td>
                            <a href="/admin/font/<%= family %>" class="btn btn-sm btn-primary">
                                <i class="glyphicon glyphicon-edit"></i> Edit
                            </a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <div class="bug-reports-section">
            <h2>Bug Reports (<%= bugReports.length %>)</h2>
            <% if (bugReports.length === 0) { %>
                <p style="color: var(--span-color);">No bug reports yet.</p>
            <% } else { %>
                <% bugReports.reverse().forEach(function(report) { %>
                    <div class="report-card">
                        <div class="report-header">
                            <div>
                                <span class="report-font"><%= report.fontFamily %></span>
                                <% if (report.fontName) { %>
                                    <span style="color: #888;"> - <%= report.fontName %></span>
                                <% } %>
                            </div>
                            <span class="status-badge <%= report.status === 'resolved' ? 'status-resolved' : 'status-open' %>">
                                <%= report.status || 'open' %>
                            </span>
                        </div>
                        <div class="report-meta">
                            <% if (report.email) { %>Email: <%= report.email %> | <% } %>
                            <% if (report.browser) { %><%= report.browser %> | <% } %>
                            <% if (report.os) { %><%= report.os %> | <% } %>
                            <%= new Date(report.createdAt).toLocaleString() %>
                        </div>
                        <div class="report-description"><%= report.description %></div>
                        <div class="report-actions">
                            <% if (report.status !== 'resolved') { %>
                                <button class="btn btn-sm btn-success resolve-btn" data-id="<%= report.id %>">Mark Resolved</button>
                            <% } else { %>
                                <button class="btn btn-sm btn-warning reopen-btn" data-id="<%= report.id %>">Reopen</button>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.resolve-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                updateStatus(this.dataset.id, 'resolved');
            });
        });
        
        document.querySelectorAll('.reopen-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                updateStatus(this.dataset.id, 'open');
            });
        });
        
        function updateStatus(id, status) {
            fetch('/admin/bug-reports/' + id, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: status })
            })
            .then(function(response) { return response.json(); })
            .then(function(result) {
                if (result.success) {
                    location.reload();
                }
            });
        }
    });
    </script>
</body>
</html>