<div class="internal-content">
  
  <% if (typeof familyMetadata !== 'undefined' && familyMetadata) { %>
  <div class="family-meta-info">
    <h2 class="family-title"><%= data.family %></h2>
    <div class="meta-details">
      <% if (familyMetadata.author) { %>
      <div class="meta-item">
        <span class="meta-label">Designed by</span>
        <span class="meta-value"><%= familyMetadata.author %></span>
      </div>
      <% } %>
      <% if (familyMetadata.foundry) { %>
      <div class="meta-item">
        <span class="meta-label">Foundry</span>
        <span class="meta-value"><%= familyMetadata.foundry %></span>
      </div>
      <% } %>
      <% if (familyMetadata.license) { %>
      <div class="meta-item">
        <span class="meta-label">License</span>
        <span class="meta-value license-badge"><%= familyMetadata.license %></span>
      </div>
      <% } %>
      <% if (familyMetadata.source) { %>
      <div class="meta-item">
        <span class="meta-label">Source</span>
        <a href="<%= familyMetadata.source %>" target="_blank" class="meta-link">View Source</a>
      </div>
      <% } %>
    </div>
    <% if (familyMetadata.description) { %>
    <p class="meta-description"><%= familyMetadata.description %></p>
    <% } %>
  </div>
  <% } %>
  
  <div class="family-instructions">
    <p>Type in the box below to try the fonts. Use the slider to adjust font size.</p>
  </div>
  
  <div class="family-header">
    <div class="input-type-toggle">
      <button class="toggle-btn active" data-type="sentence">Sentence</button>
      <button class="toggle-btn" data-type="paragraph">Paragraph</button>
    </div>
    
    <div class="input-section sentence-input active">
      <div class="field-wrapper">
        <input type="text" maxlength="100" autocomplete="off" class="kan-ime" id="type-text">
        <div class="field-placeholder"><span>Type Text</span></div>
      </div>
      <div id="slider-align">
        <div class="slidecontainer">
          <input type="range" min="8" max="100" value="50" name="range" class="slider" id="myRange">
          <output onforminput="value = range.valueAsNumber;"></output>
        </div>
      </div>
    </div>
    
    <div class="input-section paragraph-input">
      <div class="font-selector">
        <label>Select Font:</label>
        <select id="paragraphFontSelect">
          <% for(let font of data.fonts){ %>
            <option value="<%= font.font %>"><%= font.font %></option>
          <% } %>
        </select>
      </div>
      <div class="paragraph-input-row">
        <div class="field-wrapper paragraph-field">
          <textarea type="text" maxlength="500" autocomplete="off" class="kan-ime" id="type-paragraph" rows="5"></textarea>
          <div class="field-placeholder"><span>Type Paragraph</span></div>
        </div>
      </div>
      <div class="paragraph-controls">
        <div id="slider-align">
          <div class="slidecontainer">
            <input type="range" min="8" max="100" value="36" name="range" class="slider para-slider" id="paraRange">
            <output onforminput="value = paraRange.valueAsNumber;"></output>
          </div>
        </div>
        <div class="preview-box" id="paragraphPreview">
          <p></p>
        </div>
      </div>
    </div>
  </div>
  
  <div class="font-list">
      <% for(let font of data.fonts){ %> 
        <div class="font-item">
            <div class="font-item-content">
                <div class="font-info">
                    <div class="font-name">
                        <span><%= font.font %></span>
                    </div>
                    <div class="font-sample" style="font-family: '<%= font.font %>'" data-sample data-font="<%= font.font %>">
                        <p>ಪಠ್ಯವನ್ನು ಟೈಪ್ ಮಾಡಿ ಮತ್ತು ನೋಡಿ</p>
                    </div>
                </div>
                <div class="font-action">
                    <a href="/font/<%= data.link %>/<%= font.link %>" class="btn-view">
                        View Details
                    </a>
                </div>
            </div>
        </div>
      <% } %> 
  </div>
</div>

<div class="image-export-modal" id="imageModal" style="display:none;">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Download as Image</h3>
      <button class="close-modal">&times;</button>
    </div>
    <div class="modal-body">
      <div class="image-preview" id="imagePreview"></div>
    </div>
    <div class="modal-footer">
      <button class="btn-download" id="downloadImage">Download PNG</button>
      <button class="btn-copy" id="copyImage">Copy to Clipboard</button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const toggleBtns = document.querySelectorAll('.toggle-btn');
  const sentenceInput = document.querySelector('.sentence-input');
  const paragraphInput = document.querySelector('.paragraph-input');
  const typeText = document.getElementById('type-text');
  const typeParagraph = document.getElementById('type-paragraph');
  const myRange = document.getElementById('myRange');
  const paraRange = document.getElementById('paraRange');
  const fontSelect = document.getElementById('paragraphFontSelect');
  const paragraphPreview = document.getElementById('paragraphPreview');
  const fontSamples = document.querySelectorAll('.font-sample[data-sample]');
  
  // Set initial font from first font in the list
  const firstFont = fontSamples[0].dataset.font;
  typeParagraph.style.fontFamily = `'${firstFont}'`;
  paragraphPreview.style.fontFamily = `'${firstFont}'`;
  
  // Toggle between sentence and paragraph input
  toggleBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      toggleBtns.forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      const type = this.dataset.type;
      
      if (type === 'sentence') {
        sentenceInput.classList.add('active');
        paragraphInput.classList.remove('active');
      } else {
        sentenceInput.classList.remove('active');
        paragraphInput.classList.add('active');
        showExportButton();
        updateParagraphPreview();
      }
    });
  });
  
  // Sentence input handler
  typeText.addEventListener('input', function() {
    const text = this.value || 'ಪಠ್ಯವನ್ನು ಟೈಪ್ ಮಾಡಿ ಮತ್ತು ನೋಡಿ';
    fontSamples.forEach(sample => {
      sample.querySelector('p').textContent = text;
    });
  });
  
  // Font size for sentence
  myRange.addEventListener('input', function() {
    const size = this.value * 0.7;
    fontSamples.forEach(sample => {
      sample.style.fontSize = size + 'px';
    });
  });
  
  // Font selector change
  fontSelect.addEventListener('change', function() {
    const selectedFont = this.value;
    typeParagraph.style.fontFamily = `'${selectedFont}'`;
    paragraphPreview.style.fontFamily = `'${selectedFont}'`;
    updateParagraphPreview();
  });
  
  // Paragraph input handler
  typeParagraph.addEventListener('input', function() {
    updateParagraphPreview();
  });
  
  // Font size for paragraph
  paraRange.addEventListener('input', function() {
    paragraphPreview.style.fontSize = this.value + 'px';
  });
  
  function updateParagraphPreview() {
    const text = typeParagraph.value || 'ಪಠ್ಯವನ್ನು ಟೈಪ್ ಮಾಡಿ ಮತ್ತು ನೋಡಿ';
    paragraphPreview.querySelector('p').textContent = text;
  }
  
  // Initialize preview
  updateParagraphPreview();
  
  // Add export button for paragraph mode
  function showExportButton() {
    if (!document.querySelector('.export-btn')) {
      const exportBtn = document.createElement('button');
      exportBtn.className = 'export-btn';
      exportBtn.innerHTML = '<i class="glyphicon glyphicon-download-alt"></i> Export as Image';
      exportBtn.addEventListener('click', openExportModal);
      paragraphInput.querySelector('.paragraph-controls').appendChild(exportBtn);
    }
  }
  
  // Export modal
  const modal = document.getElementById('imageModal');
  const closeBtn = document.querySelector('.close-modal');
  
  closeBtn.addEventListener('click', function() {
    modal.style.display = 'none';
  });
  
  modal.addEventListener('click', function(e) {
    if (e.target === modal) {
      modal.style.display = 'none';
    }
  });
  
  function openExportModal() {
    modal.style.display = 'flex';
    const preview = document.getElementById('imagePreview');
    
    const fontFamily = paragraphPreview.style.fontFamily;
    const fontSize = paragraphPreview.style.fontSize || '36px';
    const text = paragraphPreview.querySelector('p').textContent;
    const selectedFontName = fontSelect.options[fontSelect.selectedIndex].text;
    
    preview.innerHTML = `<div class="export-content" style="font-family: ${fontFamily}; font-size: ${fontSize}; padding: 40px 50px; background: white; border-radius: 12px; text-align: center; max-width: 800px;">
      <p style="margin: 0; color: #1a1a2e; line-height: 1.6;">${text}</p>
      <div style="margin-top: 20px; padding-top: 15px; border-top: 1px solid #e0e0e0; font-size: 12px; color: #888; font-family: Arial, sans-serif;">${selectedFontName}</div>
    </div>`;
  }
  
  // Download image
  document.getElementById('downloadImage').addEventListener('click', function() {
    const content = document.querySelector('.export-content');
    const selectedFontName = fontSelect.options[fontSelect.selectedIndex].text;
    html2canvas(content, { scale: 2, backgroundColor: '#ffffff' }).then(canvas => {
      const link = document.createElement('a');
      link.download = `${selectedFontName.replace(/\s+/g, '-')}-text.png`;
      link.href = canvas.toDataURL('image/png');
      link.click();
    });
  });
  
  // Copy to clipboard
  document.getElementById('copyImage').addEventListener('click', function() {
    const content = document.querySelector('.export-content');
    html2canvas(content, { scale: 2, backgroundColor: '#ffffff' }).then(canvas => {
      canvas.toBlob(function(blob) {
        const item = new ClipboardItem({ 'image/png': blob });
        navigator.clipboard.write([item]).then(() => {
          alert('Image copied to clipboard!');
        }).catch(err => {
          console.error('Failed to copy:', err);
        });
      });
    });
  });
});
</script>